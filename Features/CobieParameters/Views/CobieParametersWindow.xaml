<Window
    x:Class="COBIeManager.Features.CobieParameters.Views.CobieParametersWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:COBIeManager.Shared.Controls"
    xmlns:converters="clr-namespace:COBIeManager.Shared.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:shared="clr-namespace:COBIeManager.Shared.Services"
    xmlns:viewModels="clr-namespace:COBIeManager.Features.CobieParameters.ViewModels"
    Title="COBie Parameters"
    Width="1200"
    Height="800"
    Background="Transparent"
    FontFamily="{DynamicResource MaterialDesignFont}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/COBIeManager;component/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToAuthStatusConverter x:Key="BoolToAuthStatusConverter" />
            <converters:BoolToAuthStatusIconConverter x:Key="BoolToAuthStatusIconConverter" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:IntegerToVisibilityConverter x:Key="IntegerToVisibilityConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

            <!--  Parameter Item Style  -->
            <Style x:Key="ParameterItem" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="8,4" />
                <Setter Property="BorderBrush" Value="#E0E0E0" />
                <Setter Property="BorderThickness" Value="1" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFF8F5" />
                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  Enhanced DataGrid Column Header Style  -->
            <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#FAFAFA" />
                <Setter Property="Foreground" Value="#424242" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="BorderBrush" Value="#E0E0E0" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F0F0F0" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  Enhanced DataGrid Cell Style  -->
            <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
                <Setter Property="BorderBrush" Value="#EEEEEE" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E3F2FD" />
                        <Setter Property="Foreground" Value="#1976D2" />
                        <Setter Property="BorderBrush" Value="#1976D2" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  Enhanced DataGrid Row Style  -->
            <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="White" />
                <Setter Property="Height" Value="Auto" />
                <Setter Property="Margin" Value="0" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F9FF" />
                    </Trigger>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="#FAFAFA" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  Modern ComboBox Style  -->
            <Style
                x:Key="ModernComboBox"
                BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
                TargetType="ComboBox">
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!--  Tool Button Style  -->
            <Style
                x:Key="ToolButton"
                BasedOn="{StaticResource MaterialDesignOutlinedButton}"
                TargetType="Button">
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Margin" Value="0,0,8,0" />
                <Setter Property="Height" Value="36" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!--  Main Content  -->
        <Border
            materialDesign:ShadowAssist.Darken="True"
            Background="#f1f1f1"
            BorderThickness="1"
            ClipToBounds="True"
            CornerRadius="5"
            SnapsToDevicePixels="True">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <!--  Header Card with Auth Status  -->
                <materialDesign:Card
                    Grid.Row="0"
                    Margin="0,0,0,16"
                    Style="{StaticResource ModernCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontSize="20"
                                Style="{StaticResource SectionHeader}"
                                Text="COBie Parameters Management" />
                            <TextBlock
                                Margin="0,0,0,0"
                                Style="{StaticResource SectionSubheader}"
                                Text="Connect to APS and add COBie parameters to your Revit project" />
                        </StackPanel>

                        <!--  Auth Status Badge  -->
                        <Border Grid.Column="1" Margin="16,0,0,0">
                            <Border.Style>
                                <Style BasedOn="{StaticResource StatusBadge}" TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                                    <Setter Property="Background" Value="#FFEBEE" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                                            <Setter Property="Background" Value="#E8F5E9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Kind="{Binding IsAuthenticated, Converter={StaticResource BoolToAuthStatusIconConverter}}">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="{Binding IsAuthenticated, Converter={StaticResource BoolToAuthStatusConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAuthenticated}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>

                <!--  Collection Selection Card  -->
                <materialDesign:Card
                    Grid.Row="1"
                    Margin="0,0,0,16"
                    Style="{StaticResource ModernCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <materialDesign:PackIcon
                            Grid.Row="0"
                            Grid.Column="0"
                            Width="24"
                            Height="24"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource PrimaryBrush}"
                            Kind="Database" />

                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                Style="{StaticResource SectionSubheader}"
                                Text="Select Collection" />
                            <ComboBox
                                materialDesign:HintAssist.Hint="Choose a collection..."
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding Collections}"
                                SelectedItem="{Binding SelectedCollection, Mode=TwoWay}"
                                Style="{StaticResource ModernComboBox}" />
                        </StackPanel>

                        <Button
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding LoginCommand}"
                            Content="Login"
                            Style="{StaticResource PrimaryActionButton}"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

                        <!--  Parameter Options Row  -->
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,12,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Kind="Settings" />
                            <TextBlock
                                Margin="0,0,16,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="Parameter Options:" />
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="Values can vary per group instance"
                                IsChecked="{Binding VariesAcrossGroups, Mode=TwoWay}"
                                Style="{StaticResource MaterialDesignCheckBox}">
                                <CheckBox.ToolTip>
                                    <ToolTip Content="When unchecked, values are aligned across all group instances (recommended for COBie). When checked, each group instance can have different values." />
                                </CheckBox.ToolTip>
                            </CheckBox>
                            <materialDesign:PackIcon
                                Width="16"
                                Height="16"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource InfoBrush}"
                                Kind="Information">
                                <materialDesign:PackIcon.ToolTip>
                                    <ToolTip Content="Controls whether parameter values are the same or can vary across Revit model group instances.&#x0a;&#x0a;Unchecked (default): All group instances share the same value - changing one changes all.&#x0a;Checked: Each group instance can have a different value." />
                                </materialDesign:PackIcon.ToolTip>
                            </materialDesign:PackIcon>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!--  Main Content Area: Label Filters (Left) + Toolbar + Parameters (Right)  -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Label Filters Sidebar  -->
                    <materialDesign:Card
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="0"
                        VerticalAlignment="Stretch"
                        Style="{StaticResource ModernCard}">
                        <Grid Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Header Section with Title and Clear Button -->
                            <DockPanel Grid.Row="0" VerticalAlignment="Center">
                                <!--  Label Filters Header  -->
                                <materialDesign:PackIcon Kind="filter" Width="30" Height="30" VerticalAlignment="Center"/>
                                <TextBlock
                                    Margin="8,8,8,12"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryTextBrush}"
                                    Text="Labels">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Labels.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!--  Clear Labels Button  -->
                                <Button                                    
                                    Padding="10,6"
                                    HorizontalAlignment="Right"
                                    Command="{Binding ClearLabelFiltersCommand}"
                                    DockPanel.Dock="Right"
                                    ToolTip="Clear Labels"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"                                            
                                            Kind="Close" />
                                        
                                    </StackPanel>
                                </Button>
                            </DockPanel>

                            <!--  Label Search Box  -->
                            <Border
                                Grid.Row="1"                               
                                Padding="8,6"
                                Background="White"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <materialDesign:PackIcon
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Foreground="#9E9E9E"
                                        Kind="Magnify" />
                                    <TextBox
                                        Margin="22,0,0,0"
                                        VerticalAlignment="Center"
                                        materialDesign:HintAssist.Hint="Search labels..."
                                        BorderThickness="0"
                                        FontSize="12"
                                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                        Text="{Binding LabelSearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                        TextWrapping="NoWrap" />
                                </Grid>
                            </Border>

                            <!--  Labels List (Chips)  -->
                            <ScrollViewer
                                Grid.Row="2"
                                VerticalScrollBarVisibility="Auto"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding FilteredLabels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="4,4"
                                                Padding="10,6"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Cursor="Hand">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F5F5F5" />
                                                        <Setter Property="BorderBrush" Value="#E0E0E0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Button
                                                    Margin="-6,-3"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Command="{Binding DataContext.ToggleLabelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <ContentPresenter />
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="#616161" />
                                                            <Setter Property="FontSize" Value="12" />
                                                            <Setter Property="FontWeight" Value="Medium" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Foreground" Value="#424242" />
                                                                </Trigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsSelected}" Value="True" />
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon
                                                            Width="14"
                                                            Height="14"
                                                            Margin="0,0,6,0"
                                                            VerticalAlignment="Center"
                                                            Kind="Check"
                                                            Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <TextBlock Text="{Binding Name}" />
                                                    </StackPanel>
                                                </Button>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Right Side: Toolbar Card  -->
                    <materialDesign:Card
                        Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,0,0,12"
                        Padding="12,8"
                        Style="{StaticResource ModernCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Button
                                    Command="{Binding SelectAllCommand}"
                                    Style="{StaticResource ToolButton}"
                                    ToolTip="Select all parameters">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Kind="SelectAll" />
                                        <TextBlock Margin="8,0,0,0" Text="Select All" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Command="{Binding DeselectAllCommand}"
                                    Style="{StaticResource ToolButton}"
                                    ToolTip="Deselect all parameters">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Kind="SelectAll" />
                                        <TextBlock Margin="8,0,0,0" Text="Deselect All" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Command="{Binding LoadParametersCommand}"
                                    Style="{StaticResource ToolButton}"
                                    ToolTip="Refresh parameters">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Kind="Refresh" />
                                        <TextBlock Margin="8,0,0,0" Text="Refresh" />
                                    </StackPanel>
                                </Button>

                                <!--  Search Box  -->
                                <Border
                                    Margin="16,0,0,0"
                                    Padding="12,8"
                                    Background="White"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Grid>
                                        <materialDesign:PackIcon
                                            Width="18"
                                            Height="18"
                                            Margin="0,0,8,0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="#9E9E9E"
                                            Kind="Magnify" />
                                        <TextBox
                                            Margin="26,0,0,0"
                                            VerticalAlignment="Center"
                                            materialDesign:HintAssist.Hint="Search parameters..."
                                            BorderThickness="0"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                            TextWrapping="NoWrap" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!--  Selection Counter Badge  -->
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <!--  Prominent selected count badge  -->
                                <Border
                                    Height="35"
                                    Padding="12,0"
                                    Background="{StaticResource PrimaryBrush}"
                                    CornerRadius="12"
                                    Visibility="{Binding SelectedCount, Converter={StaticResource IntegerToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            Foreground="White"
                                            Kind="CheckCircle" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding SelectedCount}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Foreground="White"
                                            Text=" selected" />
                                    </StackPanel>
                                </Border>


                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <!--  Parameters List Card  -->
                    <materialDesign:Card
                        Grid.Row="1"
                        Grid.Column="2"
                        Padding="0"
                        materialDesign:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <!--  Parameters Table  -->
                            <DataGrid
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserReorderColumns="False"
                                CanUserResizeColumns="False"
                                CanUserSortColumns="True"
                                GridLinesVisibility="All"
                                HeadersVisibility="Column"
                                IsReadOnly="True"
                                ItemsSource="{Binding FilteredParameters}"
                                SelectedIndex="-1"
                                SelectionMode="Single"
                                SelectionUnit="Cell"
                                Style="{StaticResource MaterialDesignDataGrid}"
                                Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn
                                        Width="50"
                                        Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        EditingElementStyle="{StaticResource MaterialDesignCheckBox}"
                                        ElementStyle="{StaticResource MaterialDesignCheckBox}" />
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Name}"
                                        FontSize="14"
                                        FontWeight="Medium"
                                        Header="Parameter Name" />
                                    <DataGridTextColumn
                                        Width="120"
                                        Binding="{Binding CollectionName}"
                                        FontSize="12"
                                        Header="Collection" />
                                    <DataGridTextColumn
                                        Width="150"
                                        Binding="{Binding LabelsDisplay}"
                                        FontSize="12"
                                        Header="Labels" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding CategoryCountDisplay}"
                                        FontSize="12"
                                        Header="Categories" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding DataTypeDisplay}"
                                        FontSize="12"
                                        Header="Type" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding InstanceTypeDisplay}"
                                        FontSize="12"
                                        Header="Inst./Type" />
                                    <DataGridTextColumn
                                        Width="140"
                                        Binding="{Binding GroupDisplay}"
                                        FontSize="12"
                                        Header="Group" />
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Height" Value="Auto" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFF8F5" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#E3F2FD" />
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                            </DataGrid>

                            <!--  Empty State (No Parameters Available)  -->
                            <Grid Background="#F9F9F9" Visibility="{Binding HasNoParametersAndNotLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon
                                        Width="72"
                                        Height="72"
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Center"
                                        Foreground="#BDBDBD"
                                        Kind="DatabaseOff" />
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        Text="No parameters available" />
                                </StackPanel>
                            </Grid>

                            <!--  Empty State (No Search Results)  -->
                            <Grid Background="#F9F9F9" Visibility="{Binding HasNoSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <materialDesign:PackIcon
                                        Width="72"
                                        Height="72"
                                        Margin="0,0,0,20"
                                        HorizontalAlignment="Center"
                                        Foreground="#BDBDBD"
                                        Kind="Magnify" />
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="Medium"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        Text="No parameters found" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="13"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        Text="Try a different search term" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </materialDesign:Card>


                </Grid>


                <!--  Footer with Status and Action Button  -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Status Message  -->
                    <Border
                        Grid.Column="0"
                        Height="40"
                        Margin="0"
                        Padding="5"
                        Style="{StaticResource InfoCard}"
                        Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource InfoBrush}"
                                Kind="Information" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource PrimaryTextBrush}"
                                Text="{Binding StatusMessage}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!--  Primary Action Button  -->
                    <Button
                        Grid.Column="1"
                        Height="40"
                        Margin="16,0,0,0"
                        Padding="24,8"
                        Command="{Binding AddToProjectCommand}"
                        FontSize="14"
                        IsEnabled="{Binding CanAddToProject}"
                        Style="{StaticResource PrimaryActionButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="18"
                                Height="18"
                                Margin="0"
                                VerticalAlignment="Center"
                                Kind="Plus" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="Add to Project" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!--  Shared Loading Overlay (covers full window)  -->
        <controls:LoadingOverlay DataContext="{x:Static shared:LoadingOverlayService.ViewModel}" />
    </Grid>


</Window>
